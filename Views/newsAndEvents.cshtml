@using Umbraco.Cms.Core.Models.PublishedContent
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "master.cshtml";
    var title = Model.Value<string>("title") ?? Model.Name;
    var bannerImage = Model.Value<IPublishedContent>("bannerImage");
}

@* Banner Image *@
@if (bannerImage != null)
{
    <div class="full-banner" style="height:250px;">
        <img src="@bannerImage.Url()" alt="@title" class="hero-bg-img" />
    </div>
}

<div class="container section-container">

    <div class="home-section-header mb-4">
        <h2 class="home-section-title">@title</h2>
    </div>

    @* Cards — JS ဖြင့် inject ဖြစ်မည် *@
    <div class="home-card-grid" id="news-result-container">
        <p class="home-empty">Loading news...</p>
    </div>

    @* Pagination — JS ဖြင့် inject ဖြစ်မည် *@
    <div id="news-pagination" class="d-flex justify-content-center mt-4 flex-wrap gap-1">
    </div>

</div>

@* News_List.js ကို ဤ page တွင်သာ load မည် *@
@section Scripts {
    <script src="/js/News_List.js"></script>
}