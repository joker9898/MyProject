@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "master.cshtml"; 
    
    var itemName = Model.Name; 
    var description = Model.Value("description"); 
    var itemImage = Model.Value<IPublishedContent>("image"); 
}

<div class="item-detail-container" style="background: #fff; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
    
    <a href="@Model.Parent.Url()" style="text-decoration: none; color: #3498db; font-weight: bold;">
        &larr; Back to Main Products
    </a>
    
    <h1 style="color: #2c3e50; margin-top: 20px;">@itemName</h1>
    
    @if (itemImage != null)
    {
        <img src="@itemImage.Url()" alt="@itemName" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin: 20px 0;" />
    }
    
    <div style="font-size: 1.1em; line-height: 1.8; color: #444;">
        @Html.Raw(description)
    </div>

</div>